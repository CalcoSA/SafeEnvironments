# ========================================================================
# Plantilla de ejemplo: .env.example
# ========================================================================
# Este archivo es una plantilla de configuración para el sistema
# "Formulario de Reporte de Acoso Sexual".
#
# Instrucciones:
# - NO incluir credenciales reales en este archivo.
# - Copie este archivo a `.env` y complete los valores sensibles.
# - En ambiente productivo, se recomienda usar variables de entorno
#   del sistema o un gestor seguro de secretos.
# - Mantenga el archivo `.env` fuera del control de versiones.
# ========================================================================

# ==========================================================================
# CONFIGURACIÓN GENERAL DE LA APLICACIÓN
# ==========================================================================

# Nombre de la aplicación
APP_NAME=Formulario de Reporte de Acoso Sexual

# Ambiente de ejecución de la aplicación:
# development -> desarrollo local
# testing     -> ambiente de pruebas / QA
# production  -> ambiente productivo
APP_ENV=development

# ==========================================================================
# CONFIGURACIÓN DE SEGURIDAD DE LA APLICACIÓN
# ==========================================================================

# Clave principal de Flask para firma de sesiones, cookies y seguridad general.
# Debe ser una cadena larga, aleatoria y segura.
SECRET_KEY=CAMBIAR_ESTA_LLAVE

# Clave utilizada específicamente para la protección CSRF de formularios.
# Si no se define, la aplicación puede usar SECRET_KEY como respaldo.
WTF_CSRF_SECRET_KEY=CAMBIAR_ESTA_LLAVE_CSRF

# Tiempo de validez del token CSRF en segundos.
# 3600 = 1 hora
WTF_CSRF_TIME_LIMIT=3600

# Indica si se habilita la auditoría de eventos de seguridad y trazabilidad.
# Valores válidos: true / false
AUDIT_LOG_ENABLED=true

# Nivel de logging de la aplicación.
# Valores comunes: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==========================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==========================================================================

# Driver de conexión utilizado por SQLAlchemy.
# Para MySQL con PyMySQL:
DB_DRIVER=mysql+pymysql

# Host o dirección IP del servidor de base de datos
DB_HOST=127.0.0.1

# Puerto del motor de base de datos
DB_PORT=3306

# Nombre de la base de datos
DB_NAME=formulario_acoso

# Usuario de conexión a la base de datos
DB_USER=root

# Contraseña del usuario de base de datos
DB_PASSWORD=secret

# Cadena completa de conexión para SQLAlchemy.
# Si se define, esta tendrá prioridad sobre DB_DRIVER, DB_HOST, DB_PORT,
# DB_NAME, DB_USER y DB_PASSWORD.
#
# Ejemplo:
# DATABASE_URL=mysql+pymysql://usuario:clave@127.0.0.1:3306/formulario_acoso?charset=utf8mb4
DATABASE_URL=

# ==========================================================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO (SMTP)
# ==========================================================================

# Servidor SMTP para envío de correos institucionales
MAIL_HOST=smtp.office365.com

# Puerto SMTP:
# 587 -> TLS
# 465 -> SSL
MAIL_PORT=587

# Usuario de autenticación SMTP
MAIL_USERNAME=notificaciones@empresa.com

# Contraseña del correo o clave de aplicación SMTP
MAIL_PASSWORD=secret

# Habilita el uso de TLS para el envío de correos
# Valores válidos: true / false
MAIL_USE_TLS=true

# Habilita el uso de SSL para el envío de correos
# Valores válidos: true / false
MAIL_USE_SSL=false

# Dirección de correo remitente
MAIL_FROM_EMAIL=notificaciones@empresa.com

# Nombre visible del remitente
MAIL_FROM_NAME=Canal Confidencial

# Lista de correos que recibirán las notificaciones internas del sistema.
# Deben ir separados por coma.
CASE_NOTIFICATION_EMAILS=talento.humano@empresa.com,comite@empresa.com

# ==========================================================================
# CONFIGURACIÓN DE ALMACENAMIENTO DE ARCHIVOS
# ==========================================================================

# Ruta base de almacenamiento privado del sistema.
# Aquí deben almacenarse archivos sensibles fuera del acceso público web.
PRIVATE_STORAGE_PATH=./private_storage

# Carpeta específica para guardar evidencias adjuntas al reporte.
EVIDENCE_UPLOAD_DIR=./private_storage/evidencias

# Carpeta de salida para los archivos PDF generados por el sistema.
PDF_OUTPUT_DIR=./generated_pdfs

# Tamaño máximo permitido para archivos cargados, en bytes.
# 10485760 = 10 MB
MAX_CONTENT_LENGTH=10485760

# Extensiones de archivo permitidas para carga de evidencias.
# Deben ir separadas por coma.
ALLOWED_FILE_EXTENSIONS=pdf,png,jpg,jpeg,doc,docx

# ==========================================================================
# CONFIGURACIÓN DE COOKIES Y SESIONES
# ==========================================================================

# Indica si la cookie de sesión solo debe enviarse por HTTPS.
# En desarrollo local suele ser false.
# En producción debe ser true.
SESSION_COOKIE_SECURE=false

# Indica si la cookie "remember me" solo debe enviarse por HTTPS.
# En producción debe ser true.
REMEMBER_COOKIE_SECURE=false

# Política SameSite de cookies.
# Valores comunes: Lax, Strict, None
SESSION_COOKIE_SAMESITE=Lax

# Tiempo de vida de la sesión en minutos.
SESSION_LIFETIME_MINUTES=30

# ------------------------------------------------------------------------
# Notas:
# - Reemplace los valores de ejemplo por datos reales en su archivo `.env`.
# - No suba el archivo `.env` al repositorio.
# - Para producción, use claves seguras, rutas privadas y HTTPS obligatorio.
# ------------------------------------------------------------------------